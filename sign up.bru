meta {
  name: sign up
  type: http
  seq: 4
}

post {
  url: {{local}}/api/auth/sign-up/email
  body: json
  auth: none
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}",
    "name": "Test",
    "lastname": "User"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
